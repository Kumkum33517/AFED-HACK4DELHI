# Server Configuration
PORT=8080
NODE_ENV=development

# API Configuration
PING_MESSAGE=pong

# Python Configuration (optional)
PYTHON_PATH=python3

# File Upload Limits
MAX_FILE_SIZE=52428800  # 50MB in bytes

# ML Configuration
ML_CONTAMINATION=0.1  # Expected anomaly rate (10%)
ML_N_ESTIMATORS=100   # Number of trees in Isolation Forest
